// ===== CANDLESTICK BACKGROUND =====
(function(){
  var canvas=document.getElementById('candleCanvas');
  if(!canvas)return;
  var ctx=canvas.getContext('2d');
  function resize(){canvas.width=window.innerWidth;canvas.height=window.innerHeight;}
  resize();
  window.addEventListener('resize',resize);
  var candles=[];
  var gold='rgba(245,166,35,';
  var green='rgba(34,197,94,';
  var red='rgba(239,68,68,';
  // Generate random candles
  for(var i=0;i<40;i++){
    var x=50+i*(window.innerWidth/38);
    var isGreen=Math.random()>0.42;
    var bodyH=20+Math.random()*80;
    var bodyY=100+Math.random()*(window.innerHeight-250);
    candles.push({x:x,bodyY:bodyY,bodyH:bodyH,isGreen:isGreen,
      wickTop:bodyY-10-Math.random()*30,
      wickBot:bodyY+bodyH+10+Math.random()*25,
      w:8+Math.random()*6,opacity:0,targetOpacity:0.3+Math.random()*0.4,
      speed:0.003+Math.random()*0.004});
  }
  var frame=0;
  function draw(){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    candles.forEach(function(c,i){
      if(frame>i*3)c.opacity=Math.min(c.targetOpacity,c.opacity+c.speed);
      var col=c.isGreen?green:red;
      // Wick
      ctx.beginPath();ctx.strokeStyle=col+c.opacity+')';ctx.lineWidth=1.5;
      ctx.moveTo(c.x,c.wickTop);ctx.lineTo(c.x,c.wickBot);ctx.stroke();
      // Body
      ctx.fillStyle=col+(c.opacity*0.7)+')';
      ctx.strokeStyle=col+c.opacity+')';
      ctx.lineWidth=1;
      ctx.beginPath();
      ctx.roundRect(c.x-c.w/2,c.bodyY,c.w,c.bodyH,2);
      ctx.fill();ctx.stroke();
    });
    frame++;
    requestAnimationFrame(draw);
  }
  draw();
})();

