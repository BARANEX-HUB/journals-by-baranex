<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Journals by Baranex — Trade Smarter. Journal Better.</title>
<meta name="description" content="The premium forex trading journal for serious ICT & SMC traders.">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --gold:#F5A623;--gold2:#FBBF24;--dark:#06060a;--dark2:#0e0e14;
  --dark3:#16161e;--dark4:#1e1e28;--text:#F0EEE8;--muted:#7a7880;
  --green:#22c55e;--red:#ef4444;--border:rgba(245,166,35,0.14);
}
body{font-family:'Montserrat',sans-serif;background:var(--dark);color:var(--text);min-height:100vh;overflow-x:hidden}
.page{display:none;min-height:100vh}.page.active{display:block}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:var(--dark2)}::-webkit-scrollbar-thumb{background:rgba(245,166,35,0.3);border-radius:3px}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;padding:.9rem 2.5rem;display:flex;align-items:center;justify-content:space-between;background:rgba(6,6,10,0.9);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);transition:all .3s}
.logo-text{display:flex;align-items:center;gap:.6rem;cursor:pointer;text-decoration:none}
.logo-mark{width:36px;height:36px;flex-shrink:0}
.logo-wordmark{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:.06em;color:var(--gold);line-height:1}
.logo-wordmark small{display:block;font-size:.55rem;color:var(--muted);letter-spacing:.12em;font-family:'Montserrat',sans-serif;font-weight:500;margin-top:1px}
.nav-right{display:flex;gap:.75rem;align-items:center}
.btn{padding:.5rem 1.25rem;border-radius:7px;border:none;cursor:pointer;font-family:'Montserrat',sans-serif;font-size:.78rem;font-weight:700;transition:all .25s;letter-spacing:.05em;text-transform:uppercase}
.btn-outline{background:transparent;border:1px solid rgba(245,166,35,0.25);color:var(--text)}
.btn-outline:hover{border-color:var(--gold);color:var(--gold)}
.btn-gold{background:var(--gold);color:#000}
.btn-gold:hover{background:var(--gold2);transform:translateY(-1px);box-shadow:0 8px 24px rgba(245,166,35,0.25)}
.btn-full{width:100%;padding:.85rem;font-size:.85rem}

/* ===================== LANDING PAGE ===================== */
#page-landing{background:var(--dark)}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:6rem 1.5rem 3rem;position:relative;overflow:hidden}
.hero-canvas{position:absolute;inset:0;z-index:0}

/* Orbs */
.orb{position:absolute;border-radius:50%;pointer-events:none}
.orb1{width:700px;height:700px;top:-200px;left:-200px;background:radial-gradient(circle,rgba(245,166,35,0.12) 0%,transparent 65%);animation:orbMove1 12s ease-in-out infinite alternate;filter:blur(60px)}
.orb2{width:600px;height:600px;bottom:-150px;right:-150px;background:radial-gradient(circle,rgba(245,166,35,0.09) 0%,transparent 65%);animation:orbMove2 15s ease-in-out infinite alternate;filter:blur(70px)}
.orb3{width:400px;height:400px;top:50%;left:50%;transform:translate(-50%,-50%);background:radial-gradient(circle,rgba(251,191,36,0.06) 0%,transparent 70%);animation:orbMove3 8s ease-in-out infinite alternate;filter:blur(50px)}
@keyframes orbMove1{from{transform:translate(0,0) scale(1)}to{transform:translate(60px,40px) scale(1.1)}}
@keyframes orbMove2{from{transform:translate(0,0) scale(1)}to{transform:translate(-40px,-60px) scale(1.15)}}
@keyframes orbMove3{from{transform:translate(-50%,-50%) scale(1)}to{transform:translate(-48%,-52%) scale(1.08)}}

/* Center glow pulse */
.hero-glow{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:900px;height:600px;background:radial-gradient(ellipse,rgba(245,166,35,0.08) 0%,transparent 55%);pointer-events:none;animation:glowBreath 5s ease-in-out infinite alternate;z-index:0}
@keyframes glowBreath{from{opacity:.6;transform:translate(-50%,-50%) scale(.95)}to{opacity:1;transform:translate(-50%,-50%) scale(1.05)}}

.hero-content{position:relative;z-index:2}
.badge-pill{display:inline-flex;align-items:center;gap:.5rem;padding:.35rem 1rem;border-radius:20px;border:1px solid rgba(245,166,35,0.25);font-size:.65rem;color:var(--gold);margin-bottom:1.75rem;background:rgba(245,166,35,0.06);letter-spacing:.1em;text-transform:uppercase;font-weight:700;animation:badgePop .6s cubic-bezier(.34,1.56,.64,1) .3s both}
@keyframes badgePop{from{opacity:0;transform:scale(.8) translateY(10px)}to{opacity:1;transform:scale(1) translateY(0)}}

.main-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(3.5rem,11vw,8.5rem);letter-spacing:.03em;line-height:.9;margin-bottom:.15em;animation:titleReveal .9s cubic-bezier(.22,1,.36,1) .5s both}
.main-title .gold{color:var(--gold)}
@keyframes titleReveal{from{opacity:0;transform:translateY(40px) skewY(2deg)}to{opacity:1;transform:translateY(0) skewY(0)}}

.sub-line{font-size:clamp(.85rem,2vw,1.1rem);font-weight:300;color:rgba(255,255,255,0.55);letter-spacing:.18em;text-transform:uppercase;margin-bottom:2rem;animation:fadeSlide .8s ease .85s both}
@keyframes fadeSlide{from{opacity:0;letter-spacing:.3em}to{opacity:1;letter-spacing:.18em}}

/* Journal box */
.journal-box{background:rgba(10,10,16,0.92);border:1px solid rgba(245,166,35,0.22);border-radius:16px;max-width:520px;margin:0 auto 2.5rem;overflow:hidden;box-shadow:0 0 60px rgba(245,166,35,0.07),inset 0 1px 0 rgba(245,166,35,0.1);animation:boxRise .9s cubic-bezier(.22,1,.36,1) 1.1s both;position:relative}
.journal-box::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(245,166,35,0.5),transparent)}
@keyframes boxRise{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
.jbar{background:rgba(22,22,30,0.9);padding:.65rem 1rem;display:flex;align-items:center;gap:.5rem;border-bottom:1px solid var(--border)}
.jdot{width:9px;height:9px;border-radius:50%}
.jdot:nth-child(1){background:#ff5f57}.jdot:nth-child(2){background:#ffbd2e}.jdot:nth-child(3){background:#28c940}
.jtitle{font-size:.62rem;color:var(--muted);margin-left:.3rem;letter-spacing:.08em;text-transform:uppercase;font-weight:700}
.jbody{padding:1.1rem 1.35rem;text-align:left;min-height:140px}
.jline{display:flex;align-items:flex-start;gap:.5rem;margin-bottom:.6rem;font-size:.8rem;line-height:1.55;opacity:0;transform:translateX(-12px);transition:all .5s cubic-bezier(.22,1,.36,1)}
.jline.show{opacity:1;transform:translateX(0)}
.jtag{font-size:.62rem;font-weight:700;letter-spacing:.06em;padding:.15rem .5rem;border-radius:4px;white-space:nowrap;margin-top:.05rem}
.jtag.inst{background:rgba(245,166,35,0.15);color:var(--gold)}
.jtag.res{background:rgba(34,197,94,0.15);color:var(--green)}
.jtag.note{background:rgba(255,255,255,0.06);color:var(--muted)}
.jtext{color:var(--text);flex:1}
.jtext .hi{color:var(--gold);font-weight:600}
.jtext .gr{color:var(--green);font-weight:600}
.cursor-blink{display:inline-block;width:2px;height:.85em;background:var(--gold);vertical-align:middle;animation:cblink .75s step-end infinite;margin-left:2px}
@keyframes cblink{0%,100%{opacity:1}50%{opacity:0}}

.hero-desc{font-size:.88rem;color:var(--muted);max-width:440px;margin:0 auto 2rem;line-height:1.85;font-weight:300;animation:fadeSlide2 .8s ease 1.4s both}
@keyframes fadeSlide2{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.hero-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;animation:fadeSlide2 .8s ease 1.6s both}
.hero-btns .btn{padding:.85rem 2.4rem;font-size:.8rem;letter-spacing:.08em}

/* ===================== FEATURES SECTION ===================== */
.section{padding:5rem 2rem;max-width:1100px;margin:0 auto}
.section-divider{height:1px;background:linear-gradient(90deg,transparent,rgba(245,166,35,0.15),transparent);margin:0 2rem}

/* Section heading */
.sec-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(2rem,5vw,3.8rem);text-align:center;margin-bottom:.3rem;letter-spacing:.06em;color:var(--gold)}
.sec-sub{text-align:center;color:var(--muted);margin-bottom:3.5rem;font-size:.85rem;letter-spacing:.04em;line-height:1.8}

.feat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem}
.feat-card{background:linear-gradient(135deg,rgba(14,14,20,0.9) 0%,rgba(22,22,30,0.6) 100%);border:1px solid var(--border);border-radius:16px;padding:1.75rem;transition:all .4s cubic-bezier(.22,1,.36,1);position:relative;overflow:hidden}
.feat-card::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(245,166,35,0.04) 0%,transparent 60%);opacity:0;transition:.4s}
.feat-card:hover{border-color:rgba(245,166,35,0.35);transform:translateY(-6px);box-shadow:0 20px 60px rgba(245,166,35,0.08)}
.feat-card:hover::after{opacity:1}
.feat-icon{width:48px;height:48px;border-radius:12px;background:rgba(245,166,35,0.1);display:flex;align-items:center;justify-content:center;font-size:1.3rem;margin-bottom:1rem;border:1px solid rgba(245,166,35,0.15);position:relative;z-index:1}
.feat-card h3{font-size:.9rem;font-weight:700;margin-bottom:.5rem;letter-spacing:.02em;position:relative;z-index:1}
.feat-card p{font-size:.8rem;color:var(--muted);line-height:1.7;font-weight:400;position:relative;z-index:1}

/* ===================== STATS TICKER ===================== */
.stats-band{background:rgba(14,14,20,0.8);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:1rem 0;overflow:hidden;position:relative}
.stats-band::before,.stats-band::after{content:'';position:absolute;top:0;bottom:0;width:100px;z-index:2}
.stats-band::before{left:0;background:linear-gradient(90deg,var(--dark),transparent)}
.stats-band::after{right:0;background:linear-gradient(-90deg,var(--dark),transparent)}
.ticker-wrap{display:flex;animation:ticker 25s linear infinite}
.ticker-item{display:flex;align-items:center;gap:.5rem;padding:0 2.5rem;white-space:nowrap;font-size:.78rem;color:var(--muted);font-weight:600;letter-spacing:.04em}
.ticker-item .val{color:var(--gold);font-family:'Bebas Neue',sans-serif;font-size:1.1rem;margin-left:.3rem}
.ticker-item .dot{width:4px;height:4px;border-radius:50%;background:rgba(245,166,35,0.3)}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ===================== HOW IT WORKS ===================== */
.steps-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2rem;position:relative}
.steps-grid::before{content:'';position:absolute;top:30px;left:10%;right:10%;height:1px;background:linear-gradient(90deg,transparent,rgba(245,166,35,0.2),transparent);pointer-events:none}
.step-item{text-align:center;position:relative}
.step-num{width:60px;height:60px;border-radius:50%;background:rgba(245,166,35,0.08);border:1px solid rgba(245,166,35,0.25);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:var(--gold);position:relative}
.step-num::after{content:'';position:absolute;inset:-3px;border-radius:50%;border:1px solid rgba(245,166,35,0.1);animation:stepPulse 3s ease-in-out infinite}
@keyframes stepPulse{0%,100%{transform:scale(1);opacity:.5}50%{transform:scale(1.1);opacity:1}}
.step-item h3{font-size:.9rem;font-weight:700;margin-bottom:.5rem;letter-spacing:.02em}
.step-item p{font-size:.78rem;color:var(--muted);line-height:1.65}

/* ===================== PRICING ===================== */
.pricing-wrap{display:flex;justify-content:center;gap:1.5rem;flex-wrap:wrap;align-items:center}
.pricing-card{background:linear-gradient(135deg,rgba(14,14,20,0.95) 0%,rgba(22,22,30,0.8) 100%);border:1px solid rgba(245,166,35,0.35);border-radius:24px;padding:2.5rem;max-width:400px;width:100%;text-align:center;position:relative;overflow:hidden;box-shadow:0 0 80px rgba(245,166,35,0.08)}
.pricing-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
.p-badge{display:inline-block;background:var(--gold);color:#000;font-size:.62rem;font-weight:800;padding:.3rem 1.2rem;border-radius:20px;letter-spacing:.1em;text-transform:uppercase;margin-bottom:1.5rem}
.p-amount{font-family:'Bebas Neue',sans-serif;font-size:5.5rem;color:var(--gold);line-height:1;letter-spacing:.02em}
.p-amount sup{font-family:'Montserrat',sans-serif;font-size:2rem;font-weight:700;vertical-align:top;margin-top:.9rem;display:inline-block}
.p-note{color:var(--muted);font-size:.72rem;margin-bottom:1.75rem;letter-spacing:.08em;text-transform:uppercase}
.p-list{list-style:none;text-align:left;margin-bottom:2rem}
.p-list li{padding:.55rem 0;font-size:.875rem;display:flex;align-items:center;gap:.75rem;border-bottom:1px solid rgba(255,255,255,0.04)}
.p-list li::before{content:"✓";color:var(--gold);font-weight:900;font-size:.85rem;flex-shrink:0}

/* ===================== TESTIMONIAL ===================== */
.testimonial-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem}
.tcard{background:rgba(14,14,20,0.8);border:1px solid var(--border);border-radius:14px;padding:1.5rem;transition:.3s}
.tcard:hover{border-color:rgba(245,166,35,0.25);transform:translateY(-3px)}
.tcard-stars{color:var(--gold);font-size:.9rem;margin-bottom:.75rem;letter-spacing:.1em}
.tcard-text{font-size:.83rem;color:var(--text);line-height:1.75;margin-bottom:1rem;font-style:italic;opacity:.85}
.tcard-author{display:flex;align-items:center;gap:.75rem}
.tcard-avatar{width:36px;height:36px;border-radius:50%;background:rgba(245,166,35,0.15);border:1px solid rgba(245,166,35,0.25);display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;color:var(--gold)}
.tcard-name{font-size:.8rem;font-weight:700;letter-spacing:.02em}
.tcard-role{font-size:.7rem;color:var(--muted)}

/* ===================== FOOTER ===================== */
.footer-main{background:rgba(10,10,14,0.95);border-top:1px solid var(--border);padding:3rem 2rem 1.5rem}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:2rem;max-width:1000px;margin:0 auto 2rem}
.footer-brand .fn{font-family:'Bebas Neue',sans-serif;color:var(--gold);font-size:1.4rem;letter-spacing:.06em;margin-bottom:.5rem}
.footer-brand p{font-size:.78rem;color:var(--muted);line-height:1.7;max-width:280px}
.footer-col h4{font-size:.72rem;color:var(--gold);font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:.75rem}
.footer-col a{display:block;font-size:.78rem;color:var(--muted);margin-bottom:.4rem;cursor:pointer;transition:.2s}
.footer-col a:hover{color:var(--text)}
.footer-bottom{text-align:center;border-top:1px solid var(--border);padding-top:1.5rem;font-size:.72rem;color:var(--muted)}

/* ===================== APP STYLES (keep all existing) ===================== */
.auth-page{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:2rem;padding-top:6rem}
.auth-box{background:var(--dark2);border:1px solid var(--border);border-radius:18px;padding:2.5rem;width:100%;max-width:400px}
.auth-box h2{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:.05em;margin-bottom:.25rem}
.auth-box p{color:var(--muted);font-size:.82rem;margin-bottom:2rem}
.auth-tabs{display:flex;background:var(--dark3);border-radius:8px;padding:3px;margin-bottom:1.5rem}
.atab{flex:1;padding:.5rem;text-align:center;border-radius:6px;cursor:pointer;font-size:.75rem;color:var(--muted);transition:all .2s;font-weight:700;letter-spacing:.05em;text-transform:uppercase}
.atab.active{background:var(--gold);color:#000}
.fg{margin-bottom:1rem}
.fg label{display:block;font-size:.68rem;color:var(--muted);margin-bottom:.4rem;letter-spacing:.07em;text-transform:uppercase;font-weight:700}
.fg input{width:100%;padding:.75rem 1rem;background:var(--dark3);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Montserrat',sans-serif;font-size:.875rem;outline:none;transition:border .2s}
.fg input:focus{border-color:var(--gold)}
.auth-msg{text-align:center;font-size:.8rem;padding:.6rem;border-radius:6px;margin-bottom:.75rem;display:none}
.auth-msg.err{background:rgba(239,68,68,0.1);color:var(--red);display:block}
.auth-msg.ok{background:rgba(34,197,94,0.1);color:var(--green);display:block}
.app-layout{display:flex;min-height:100vh}
.sidebar{width:230px;background:var(--dark2);border-right:1px solid var(--border);padding:1.5rem 1rem;position:fixed;top:0;left:0;bottom:0;z-index:50;display:flex;flex-direction:column;gap:.2rem;overflow-y:auto}
.sb-logo{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:var(--gold);letter-spacing:.05em;padding:.75rem 1rem 1.5rem;line-height:1.3}
.sb-logo span{display:block;font-family:'Montserrat',sans-serif;font-size:.6rem;color:var(--muted);font-weight:500;letter-spacing:.04em;margin-top:.2rem}
.ni{display:flex;align-items:center;gap:.75rem;padding:.65rem 1rem;border-radius:8px;cursor:pointer;font-size:.8rem;color:var(--muted);transition:all .2s;font-weight:600;letter-spacing:.02em}
.ni:hover,.ni.active{background:rgba(245,166,35,0.1);color:var(--gold)}
.ni .ic{font-size:.9rem;width:18px;text-align:center}
.mc{margin-left:230px;flex:1;padding:6rem 2rem 2rem;min-height:100vh}
.ph{margin-bottom:2rem}
.ph h2{font-family:'Bebas Neue',sans-serif;font-size:1.9rem;letter-spacing:.04em}
.ph p{color:var(--muted);font-size:.8rem;margin-top:.2rem}
.sg{display:grid;grid-template-columns:repeat(auto-fit,minmax(145px,1fr));gap:1rem;margin-bottom:2rem}
.sc{background:var(--dark2);border:1px solid var(--border);border-radius:12px;padding:1.25rem}
.sl{font-size:.63rem;color:var(--muted);margin-bottom:.5rem;text-transform:uppercase;letter-spacing:.08em;font-weight:700}
.sv{font-family:'Bebas Neue',sans-serif;font-size:2.2rem;letter-spacing:.03em}
.sv.gold{color:var(--gold)}.sv.green{color:var(--green)}.sv.red{color:var(--red)}
.sch{font-size:.7rem;color:var(--muted);margin-top:.2rem}
.cg{display:grid;grid-template-columns:2fr 1fr;gap:1rem;margin-bottom:2rem}
.cb{background:var(--dark2);border:1px solid var(--border);border-radius:12px;padding:1.5rem}
.cb h3{font-size:.63rem;color:var(--muted);margin-bottom:1.25rem;text-transform:uppercase;letter-spacing:.1em;font-weight:700}
.tw{background:var(--dark2);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:1.5rem}
.th2{padding:1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border)}
.th2 h3{font-family:'Bebas Neue',sans-serif;font-size:1.05rem;letter-spacing:.05em;color:var(--gold)}
table{width:100%;border-collapse:collapse}
th{padding:.65rem 1rem;font-size:.62rem;color:var(--muted);text-align:left;border-bottom:1px solid var(--border);font-weight:700;text-transform:uppercase;letter-spacing:.06em}
td{padding:.75rem 1rem;font-size:.78rem;border-bottom:1px solid rgba(255,255,255,0.03)}
tr:last-child td{border:none}
tr:hover td{background:rgba(245,166,35,0.02)}
.bw{background:rgba(34,197,94,0.12);color:var(--green);padding:.2rem .6rem;border-radius:4px;font-size:.65rem;font-weight:700;letter-spacing:.04em}
.bl{background:rgba(239,68,68,0.12);color:var(--red);padding:.2rem .6rem;border-radius:4px;font-size:.65rem;font-weight:700;letter-spacing:.04em}
.bb{background:rgba(245,166,35,0.12);color:var(--gold);padding:.2rem .6rem;border-radius:4px;font-size:.65rem;font-weight:700}
.db{color:var(--green);font-weight:700}.ds{color:var(--red);font-weight:700}
.fgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(195px,1fr));gap:1rem}
.frow{background:var(--dark2);border:1px solid var(--border);border-radius:12px;padding:1.5rem;margin-bottom:1rem}
.frow h3{font-family:'Bebas Neue',sans-serif;font-size:.9rem;letter-spacing:.08em;color:var(--gold);margin-bottom:1rem}
.finput{width:100%;padding:.7rem 1rem;background:var(--dark3);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Montserrat',sans-serif;font-size:.825rem;outline:none;transition:border .2s}
.finput:focus{border-color:var(--gold)}
textarea.finput{resize:vertical;min-height:80px}
.stars{display:flex;gap:.3rem;font-size:1.5rem;cursor:pointer}
.star{color:var(--dark4);transition:color .15s}.star.on{color:var(--gold)}
.mtags{display:flex;flex-wrap:wrap;gap:.5rem}
.mtag{padding:.3rem .75rem;border-radius:20px;border:1px solid var(--border);font-size:.7rem;cursor:pointer;color:var(--muted);transition:all .2s;font-weight:600}
.mtag.on{border-color:var(--gold);color:var(--gold);background:rgba(245,166,35,0.1)}
.ch{text-align:center;font-size:.62rem;color:var(--muted);padding:.5rem 0;font-weight:700;letter-spacing:.06em;text-transform:uppercase}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
.cday{aspect-ratio:1;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-direction:column;font-size:.65rem;border:1px solid var(--border);background:var(--dark2);cursor:pointer;transition:.2s;font-weight:600}
.cday:hover{border-color:var(--gold)}
.cday.win{background:rgba(34,197,94,0.08);border-color:rgba(34,197,94,0.25)}
.cday.loss{background:rgba(239,68,68,0.08);border-color:rgba(239,68,68,0.25)}
.cday .dp{font-size:.58rem;color:var(--green)}.cday.loss .dp{color:var(--red)}
.ag{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:1rem}
.lock-banner{background:var(--dark2);border:1px solid rgba(245,166,35,0.4);border-radius:14px;padding:2rem;text-align:center;margin-bottom:1.5rem}
