function updateDashboard(){
  var t=allTrades;
  var wins=t.filter(function(x){return x.result==='Win'}).length;
  var total=t.length;
  var wr=total?Math.round(wins/total*100):0;
  document.getElementById('stat-trades').textContent=total;
  document.getElementById('stat-wr').textContent=wr+'%';
  // Simple R calc
  var totalR=0;
  t.forEach(function(tr){
    if(tr.result==='Win')totalR+=2;
    else if(tr.result==='Loss')totalR-=1;
  });
  document.getElementById('stat-r').textContent=(totalR>=0?'+':'')+totalR.toFixed(1)+'R';
  document.getElementById('stat-pf').textContent=wins&&(total-wins)?(wins/(total-wins)).toFixed(2):'—';
  renderRecentTrades(t.slice(-5).reverse());
  renderAllTrades(t.slice().reverse());
  if(!dashDone){initDashCharts(t);dashDone=true;}
  buildCal(t);
}

function renderRecentTrades(trades){
  var el=document.getElementById('recent-trades-body');
  if(!el)return;
  if(!trades.length){el.innerHTML='<tr><td colspan="7" style="text-align:center;color:var(--muted);padding:2rem">No trades yet. Add your first trade!</td></tr>';return;}
  el.innerHTML=trades.map(function(t){
    var d=new Date(t.date);
    var dateStr=d.toLocaleDateString('en-IN',{day:'numeric',month:'short'});
    var rb=t.result==='Win'?'bw':t.result==='Loss'?'bl':'bb';
    return '<tr><td>'+dateStr+'</td><td>'+t.instrument+'</td><td class="'+(t.direction==='BUY'?'db':'ds')+'">'+t.direction+'</td><td>'+t.session+'</td><td>'+(t.strategy_tag||'—')+'</td><td>'+(t.rr_ratio||'—')+'</td><td><span class="'+rb+'">'+t.result.toUpperCase()+'</span></td></tr>';
  }).join('');
}

function renderAllTrades(trades){
  var el=document.getElementById('all-trades-body');
  if(!el)return;
  if(!trades.length){el.innerHTML='<tr><td colspan="11" style="text-align:center;color:var(--muted);padding:2rem">No trades yet.</td></tr>';return;}
  el.innerHTML=trades.map(function(t){
    var d=new Date(t.date);
    var dateStr=d.toLocaleDateString('en-IN',{day:'numeric',month:'short'});
    var rb=t.result==='Win'?'bw':t.result==='Loss'?'bl':'bb';
    var stars='⭐'.repeat(t.emotional_rating||0);
    return '<tr><td>'+dateStr+'</td><td>'+t.instrument+'</td><td class="'+(t.direction==='BUY'?'db':'ds')+'">'+t.direction+'</td><td>'+t.session+'</td><td>'+(t.entry_price||'—')+'</td><td>'+(t.stop_loss||'—')+'</td><td>'+(t.take_profit||'—')+'</td><td>'+(t.rr_ratio||'—')+'</td><td>'+(t.strategy_tag||'—')+'</td><td>'+stars+'</td><td><span class="'+rb+'">'+t.result.toUpperCase()+'</span></td></tr>';
  }).join('');
}

// ===== FORM =====
function calcRR(){
  var e=parseFloat(document.getElementById('f-entry').value);
  var sl=parseFloat(document.getElementById('f-sl').value);
  var tp=parseFloat(document.getElementById('f-tp').value);
  if(e&&sl&&tp&&e!==sl){
    var risk=Math.abs(e-sl);
    var reward=Math.abs(tp-e);
    var rr=(reward/risk).toFixed(1);
    document.getElementById('f-rr').value='1:'+rr;
  }
}

function rateStar(n){
  emotionRating=n;
  document.querySelectorAll('.star').forEach(function(s,i){s.classList.toggle('on',i<n)});
}

function handleFile(file){
  if(!file)return;
  var reader=new FileReader();
  reader.onload=function(e){
    screenshotBase64=e.target.result;
    document.getElementById('ss-img').src=e.target.result;
    document.getElementById('ss-preview').style.display='block';
  };
  reader.readAsDataURL(file);
}

function handleDrop(e){
  e.preventDefault();
  var file=e.dataTransfer.files[0];
  if(file)handleFile(file);
}

async function saveTrade(){
  var btn=document.getElementById('save-btn');
  var msg=document.getElementById('save-msg');
  if(!supabase||!currentUser){
    msg.textContent='Please login first';msg.className='auth-msg err';return;
  }
  btn.textContent='SAVING...';btn.disabled=true;
  var mistake=[];
  document.querySelectorAll('.mtag.on').forEach(function(t){mistake.push(t.textContent)});
  var trade={
    user_id:currentUser.id,
    date:document.getElementById('f-date').value||new Date().toISOString(),
    instrument:document.getElementById('f-inst').value,
    session:document.getElementById('f-sess').value,
    direction:document.getElementById('f-dir').value,
    entry_price:parseFloat(document.getElementById('f-entry').value)||null,
    stop_loss:parseFloat(document.getElementById('f-sl').value)||null,
    take_profit:parseFloat(document.getElementById('f-tp').value)||null,
    rr_ratio:document.getElementById('f-rr').value,
    lot_size:parseFloat(document.getElementById('f-lot').value)||null,
    result:document.getElementById('f-res').value,
    strategy_tag:document.getElementById('f-strat').value,
    pips:parseFloat(document.getElementById('f-pips').value)||null,
    pre_trade_notes:document.getElementById('f-pre').value,
    post_trade_notes:document.getElementById('f-post').value,
    emotional_rating:emotionRating,
    mistake_tag:mistake.join(', '),
    screenshot_url:screenshotBase64||null
  };
  var {error}=await supabase.from('trades').insert(trade);
  btn.textContent='SAVE TRADE ✓';btn.disabled=false;
  if(error){msg.textContent='Error: '+error.message;msg.className='auth-msg err';}
  else{
    msg.textContent='Trade saved successfully!';msg.className='auth-msg ok';
    allTrades.push(trade);
    dashDone=false;updateDashboard();
    setTimeout(function(){swApp('tradelog',null);},1200);
  }
}

// ===== CHARTS =====
var chartInstances={};
function destroyChart(id){if(chartInstances[id]){chartInstances[id].destroy();delete chartInstances[id];}}

function initDashCharts(trades){
  var g='#F5A623',gr='#22c55e',r='#ef4444',m='rgba(136,135,128,0.15)';
  // Equity curve
  var eq=document.getElementById('eq');
  if(eq){
    destroyChart('eq');
    var labels=['Start'];var data=[0];var cum=0;
    trades.forEach(function(t,i){
      labels.push('T'+(i+1));
      if(t.result==='Win')cum+=2;else if(t.result==='Loss')cum-=1;
      data.push(parseFloat(cum.toFixed(2)));
    });
    if(data.length===1){labels.push('T1');data.push(0);}
    chartInstances['eq']=new Chart(eq,{type:'line',data:{labels:labels,datasets:[{data:data,borderColor:g,backgroundColor:'rgba(245,166,35,0.06)',fill:true,tension:.4,pointRadius:3,pointBackgroundColor:g,borderWidth:2}]},options:{responsive:true,plugins:{legend:{display:false}},scales:{x:{grid:{color:m},ticks:{color:'#666',font:{size:9}}},y:{grid:{color:m},ticks:{color:'#666',font:{size:9}}}}}});
  }
  var wl=document.getElementById('wl');
  if(wl){
    destroyChart('wl');
    var wins=trades.filter(function(t){return t.result==='Win'}).length;
    var losses=trades.filter(function(t){return t.result==='Loss'}).length;
    var be=trades.filter(function(t){return t.result==='Breakeven'}).length;
    chartInstances['wl']=new Chart(wl,{type:'doughnut',data:{labels:['Win','Loss','BE'],datasets:[{data:[wins||1,losses,be],backgroundColor:[gr,r,g],borderWidth:0,borderRadius:3}]},options:{responsive:true,cutout:'68%',plugins:{legend:{position:'bottom',labels:{color:'#888',font:{size:10},padding:10}}}}});
  }
}

function initAnalyticsCharts(){
  if(analDone)return;analDone=true;
  var g='#F5A623',gr='#22c55e',r='#ef4444',m='rgba(136,135,128,0.15)';
  var baseOpts={responsive:true,plugins:{legend:{display:false}},scales:{x:{grid:{color:m},ticks:{color:'#666',font:{size:9}}},y:{grid:{color:m},ticks:{color:'#666',font:{size:9}}}}};
  var t=allTrades;

  // By instrument
  var insts=['US30','XAUUSD','EURUSD','GBPUSD','NAS100'];
  var instR=insts.map(function(ins){
    var it=t.filter(function(x){return x.instrument===ins});
    var r=0;it.forEach(function(x){if(x.result==='Win')r+=2;else if(x.result==='Loss')r-=1;});return r;
  });
  var ic=document.getElementById('ic');
  if(ic){destroyChart('ic');chartInstances['ic']=new Chart(ic,{type:'bar',data:{labels:insts,datasets:[{data:instR,backgroundColor:instR.map(function(v){return v>=0?g:r}),borderRadius:5}]},options:baseOpts});}

  // By session
  var sess=['London','New York','Asian','Overlap'];
  var sessR=sess.map(function(s){
    var st=t.filter(function(x){return x.session===s});
    var rv=0;st.forEach(function(x){if(x.result==='Win')rv+=2;else if(x.result==='Loss')rv-=1;});return rv;
  });
  var sc=document.getElementById('scc');
  if(sc){destroyChart('scc');chartInstances['scc']=new Chart(sc,{type:'bar',data:{labels:sess,datasets:[{data:sessR,backgroundColor:gr,borderRadius:5}]},options:baseOpts});}

  // Mistakes
  var mkeys=['Perfect Execution','FOMO','Moved SL','Revenge Trade','Overleverage'];
  var mvals=mkeys.map(function(k){return t.filter(function(x){return x.mistake_tag&&x.mistake_tag.includes(k)}).length});
  var mc=document.getElementById('mcc');
  if(mc){destroyChart('mcc');chartInstances['mcc']=new Chart(mc,{type:'bar',data:{labels:mkeys,datasets:[{data:mvals,backgroundColor:[gr,r,r,r,r],borderRadius:5}]},options:baseOpts});}

  // Strategy win rate
  var strats=['FVG','Order Block','CHoCH','Liquidity Sweep','BOS'];
  var stratWR=strats.map(function(s){
    var st=t.filter(function(x){return x.strategy_tag===s});
    if(!st.length)return 0;
    return Math.round(st.filter(function(x){return x.result==='Win'}).length/st.length*100);
  });
  var stc=document.getElementById('stcc');
  if(stc){destroyChart('stcc');chartInstances['stcc']=new Chart(stc,{type:'bar',data:{labels:strats,datasets:[{data:stratWR,backgroundColor:g,borderRadius:5}]},options:baseOpts});}

  // Update analytics stats
  var bestSessIdx=sessR.indexOf(Math.max.apply(null,sessR));
  document.getElementById('a-sess').textContent=sessR[bestSessIdx]>0?sess[bestSessIdx]:'—';
  var bestInstIdx=instR.indexOf(Math.max.apply(null,instR));
  document.getElementById('a-inst').textContent=instR[bestInstIdx]>0?insts[bestInstIdx]:'—';
  // Streak
  var streak=0,maxStreak=0,cur=0;
  t.forEach(function(tr){if(tr.result==='Win'){cur++;streak=Math.max(streak,cur);}else cur=0;});
  document.getElementById('a-streak').textContent=streak;
  // Avg emotion
  var emos=t.filter(function(x){return x.emotional_rating}).map(function(x){return x.emotional_rating});
  var avgEmo=emos.length?( emos.reduce(function(a,b){return a+b},0)/emos.length).toFixed(1):0;
  document.getElementById('a-emo').textContent=avgEmo+'★';
}

function buildCal(trades){
  var g=document.getElementById('calg');
  if(!g)return;
  g.innerHTML='';
  var now=new Date();
  var yr=now.getFullYear(),mo=now.getMonth();
  var firstDay=new Date(yr,mo,1).getDay();
  var daysInMonth=new Date(yr,mo+1,0).getDate();
  // Adjust to Mon start
  var offset=(firstDay+6)%7;
  for(var i=0;i<offset;i++){var b=document.createElement('div');b.style.height='52px';g.appendChild(b);}
  for(var d=1;d<=daysInMonth;d++){
    var dayTrades=trades.filter(function(t){
      var td=new Date(t.date);
      return td.getFullYear()===yr&&td.getMonth()===mo&&td.getDate()===d;
    });
    var div=document.createElement('div');div.className='cday';
    var wins=dayTrades.filter(function(t){return t.result==='Win'}).length;
    var losses=dayTrades.filter(function(t){return t.result==='Loss'}).length;
    if(dayTrades.length){
      if(wins>=losses)div.classList.add('win');else div.classList.add('loss');
      var r=0;dayTrades.forEach(function(t){if(t.result==='Win')r+=2;else if(t.result==='Loss')r-=1;});
      div.innerHTML='<span>'+d+'</span><span class="dp">'+(r>=0?'+':'')+r.toFixed(1)+'R</span>';
    } else {
      div.innerHTML='<span>'+d+'</span>';
    }
    g.appendChild(div);
  }
}

// ===== NAVIGATION =====
function swApp(v,el){
  document.querySelectorAll('[id^="v-"]').forEach(function(x){x.style.display='none'});
  var view=document.getElementById('v-'+v);
  if(view)view.style.display='block';
  document.querySelectorAll('.ni').forEach(function(n){n.classList.remove('active')});
  document.querySelectorAll('.bni').forEach(function(n){n.classList.remove('active')});
  if(el)el.classList.add('active');
  if(v==='analytics'){setTimeout(initAnalyticsCharts,150);}
  if(v==='calendar'){buildCal(allTrades);}
  // Set date default
  if(v==='addtrade'){
    var now=new Date();
    var local=new Date(now.getTime()-now.getTimezoneOffset()*60000).toISOString().slice(0,16);
    document.getElementById('f-date').value=local;
  }
}

