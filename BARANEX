<script>
// ===== PREMIUM HERO CANVAS =====
(function(){
  var canvas=document.getElementById('heroCanvas');
  if(!canvas)return;
  var ctx=canvas.getContext('2d');
  var W,H,particles=[],candles=[],lines=[],frame=0;

  function resize(){
    W=canvas.width=window.innerWidth;
    H=canvas.height=window.innerHeight;
  }
  resize();
  window.addEventListener('resize',function(){resize();initAll();});

  // Gold color helper
  function gold(a){return 'rgba(245,166,35,'+a+')';}
  function green(a){return 'rgba(34,197,94,'+a+')';}
  function red(a){return 'rgba(239,68,68,'+a+')';}

  function initAll(){
    particles=[];candles=[];lines=[];

    // PARTICLES
    for(var i=0;i<60;i++){
      particles.push({
        x:Math.random()*W, y:Math.random()*H,
        vx:(Math.random()-.5)*.3, vy:-0.2-Math.random()*.5,
        r:0.5+Math.random()*2, a:0.1+Math.random()*.4,
        life:Math.random()
      });
    }

    // CANDLESTICKS across full page
    var cols=Math.floor(W/45);
    for(var i=0;i<cols;i++){
      var isGreen=Math.random()>.42;
      var bodyH=15+Math.random()*70;
      var bodyY=H*.15+Math.random()*(H*.65);
      candles.push({
        x:20+i*(W/cols)+Math.random()*15,
        bodyY:bodyY, bodyH:bodyH,
        wickT:bodyY-8-Math.random()*25,
        wickB:bodyY+bodyH+8+Math.random()*20,
        w:5+Math.random()*6,
        isGreen:isGreen,
        a:0, maxA:0.08+Math.random()*.1,
        speed:0.002+Math.random()*.003
      });
    }

    // DIAGONAL LINES
    for(var i=0;i<8;i++){
      lines.push({
        x:-W*.3+Math.random()*W*1.6,
        y:Math.random()*H,
        len:100+Math.random()*300,
        angle:-30+Math.random()*60,
        a:0, maxA:0.06+Math.random()*.08,
        speed:0.001+Math.random()*.002,
        dx:(Math.random()-.5)*.3,
        dy:(Math.random()-.5)*.2
      });
    }
  }
  initAll();

  function drawGrid(){
    var size=65;
    ctx.strokeStyle=gold(0.03);
    ctx.lineWidth=.5;
    // Animated offset
    var off=(frame*.3)%size;
    for(var x=-size+off;x<W+size;x+=size){
      ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();
    }
    for(var y=-size+off;y<H+size;y+=size){
      ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();
    }
  }

  function drawCandles(){
    candles.forEach(function(c){
      c.a=Math.min(c.maxA,c.a+c.speed);
      var col=c.isGreen?green:red;
      // Wick
      ctx.beginPath();
      ctx.strokeStyle=col(c.a);
      ctx.lineWidth=1;
      ctx.moveTo(c.x,c.wickT);ctx.lineTo(c.x,c.wickB);ctx.stroke();
      // Body
      ctx.fillStyle=col(c.a*.7);
      ctx.strokeStyle=col(c.a);
      ctx.lineWidth=.8;
      ctx.beginPath();
      ctx.roundRect?ctx.roundRect(c.x-c.w/2,c.bodyY,c.w,c.bodyH,2):ctx.rect(c.x-c.w/2,c.bodyY,c.w,c.bodyH);
      ctx.fill();ctx.stroke();
    });
  }

  function drawParticles(){
    particles.forEach(function(p){
      p.life+=0.003;
      if(p.life>1){p.life=0;p.x=Math.random()*W;p.y=H+10;p.a=0.1+Math.random()*.4;}
      p.x+=p.vx;p.y+=p.vy;
      var flicker=0.7+0.3*Math.sin(p.life*20+p.x);
      ctx.beginPath();
      ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle=gold(p.a*flicker*(1-p.life*.5));
      ctx.fill();
    });
  }

  function drawLines(){
    lines.forEach(function(l){
      l.a=Math.min(l.maxA,l.a+l.speed);
      l.x+=l.dx;l.y+=l.dy;
      if(l.x>W*1.3)l.x=-l.len;
      if(l.x<-l.len)l.x=W*1.3;
      if(l.y<0)l.y=H;if(l.y>H)l.y=0;
      var rad=l.angle*Math.PI/180;
      var x2=l.x+Math.cos(rad)*l.len;
      var y2=l.y+Math.sin(rad)*l.len;
      var grad=ctx.createLinearGradient(l.x,l.y,x2,y2);
      grad.addColorStop(0,'transparent');
      grad.addColorStop(.5,gold(l.a));
      grad.addColorStop(1,'transparent');
      ctx.beginPath();
      ctx.strokeStyle=grad;
      ctx.lineWidth=.8;
      ctx.moveTo(l.x,l.y);ctx.lineTo(x2,y2);ctx.stroke();
    });
  }

  // Connection lines between nearby particles
  function drawConnections(){
    for(var i=0;i<particles.length;i++){
      for(var j=i+1;j<particles.length;j++){
        var dx=particles[i].x-particles[j].x;
        var dy=particles[i].y-particles[j].y;
        var dist=Math.sqrt(dx*dx+dy*dy);
        if(dist<120){
          ctx.beginPath();
          ctx.strokeStyle=gold((1-dist/120)*0.05);
          ctx.lineWidth=.5;
          ctx.moveTo(particles[i].x,particles[i].y);
          ctx.lineTo(particles[j].x,particles[j].y);
          ctx.stroke();
        }
      }
    }
  }

  function animate(){
    ctx.clearRect(0,0,W,H);
    if(document.getElementById('page-landing').classList.contains('active')){
      drawGrid();
      drawCandles();
      drawLines();
      drawConnections();
      drawParticles();
      frame++;
    }
    requestAnimationFrame(animate);
  }
  animate();
})();

